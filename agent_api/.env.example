# =============================================================================
# agent_api/.env — copie este archivo como .env y complete los valores reales
# =============================================================================

# Obligatorio — API de DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# LLM
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SEC=60

# Servidor FastAPI
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cubo SSAS Tabular (ADOMD). Ajuste Data Source y Initial Catalog a su entorno.
DEFAULT_CUBE_ADDRESS=Provider=MSOLAP;Data Source=YOUR_SSAS_HOST;Initial Catalog=CB_BI_FlotHs;

# true = datos simulados sin conectar a SSAS (desarrollo sin red corporativa)
SSAS_USE_MOCK=false

# Permitir que el cliente envíe cube_address (panel Fuentes de datos). false = solo DEFAULT del servidor
ALLOW_CLIENT_CUBE_ADDRESS=true

# Agente
AGENT_DEBUG=true
AGENT_REQUEST_TIMEOUT_SEC=120
AGENT_RECURSION_LIMIT=50
# Reintentos del pipeline multi-agente (execute_dax → dax_translator)
MAX_DAX_RETRIES=3

# Desarrollo: hot-reload de uvicorn (false en despliegue estable)
UVICORN_RELOAD=true

# Dashboard ejecutivo (opcional; por defecto agent_api/data/dashboard.json)
# DASHBOARD_STORE_PATH=agent_api/data/dashboard.json

# Catálogo de fuentes (seudonimo, ruta_cubo, ruta_power_bi, ruta_diccionario) — editable
# DATA_SOURCES_CSV_PATH=agent_api/data/fuentes_datos.csv
