# =============================================================================
# agent_api/.env — copie este archivo como .env y complete los valores reales
# =============================================================================

# Obligatorio — API de DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# LLM
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SEC=60

# Servidor FastAPI
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Cubo SSAS Tabular (ADOMD). Ajuste Data Source y Initial Catalog a su entorno.
DEFAULT_CUBE_ADDRESS=Provider=MSOLAP;Data Source=YOUR_SSAS_HOST;Initial Catalog=CB_BI_FlotHs;

# true = datos simulados sin conectar a SSAS (desarrollo sin red corporativa)
SSAS_USE_MOCK=false

# Permitir que el cliente envíe cube_address en el body (solo dev; false en producción)
ALLOW_CLIENT_CUBE_ADDRESS=false

# Agente
AGENT_DEBUG=true
AGENT_REQUEST_TIMEOUT_SEC=90
AGENT_RECURSION_LIMIT=10

# Dashboard ejecutivo (opcional; por defecto agent_api/data/dashboard.json)
# DASHBOARD_STORE_PATH=agent_api/data/dashboard.json
