# =============================================================================
# frontend_ui/.env — copie como .env (o deje que docker-compose lo genere)
# =============================================================================

# URL del backend Python (BFF → agent_api)
# Docker en Windows:
AGENT_API_URL=http://host.docker.internal:8000
# Desarrollo local sin Docker:
# AGENT_API_URL=http://localhost:8000

# Opcional: IP del host Windows (scripts/docker-up.ps1 la detecta)
# HOST_IP=10.0.15.184

# Cadena del cubo por defecto (el panel "Fuentes de datos" puede sobrescribirla en el navegador)
# DEFAULT_CUBE_ADDRESS=Provider=MSOLAP;Data Source=YOUR_SSAS_HOST;Initial Catalog=CB_BI_FlotHs;
# ALLOW_CLIENT_CUBE_ADDRESS=true

# Timeout del chat (ms). Debe ser >= AGENT_REQUEST_TIMEOUT_SEC del backend (120s).
CHAT_TIMEOUT_MS=125000
